# --- Database ---
# In local dev, `nk dev` boots PGlite and sets DATABASE_URL automatically.
# In prod this is the DigitalOcean managed Postgres connection string.
DATABASE_URL=

# --- Auth (Better Auth) ---
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# Optional GitHub OAuth (org-gated employee login)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Ingram Cloud (inference) ---
# Tenant-admin token used server-side to mint smith tokens / call inference.
INGRAM_CLOUD_TOKEN=
INGRAM_CLOUD_BASE_URL=https://api.cloud.ingram.tech/v1
# Agent ids produced by `pulumi up` in ./pulumi (also discoverable by slug)
DEPOT_EXTRACTOR_AGENT_ID=
DEPOT_CANONICALIZER_AGENT_ID=
DEPOT_BRIEFER_AGENT_ID=

# --- Ingest ---
# Shared secret used to sign/verify plugin upload tokens.
INGEST_TOKEN_SECRET=
